function checkJoin() {
    if(frm.drv_date.value.length==0) {
        alert("주행일자가 입력되지 않았습니다!")
        frm.drv_date.focus();
        return false;
    }

    //모든 속성에 대해 유효성 검사
    if(frm.car_no.value=="") {
        alert("차량번호가 입력되지 않았습니다!")
        frm.car_no.focus();
        return false;
    }

    if(frm.drv_start.value=="") {
        alert("출발Km 입력되지 않았습니다.")
        frm.drv_start.focus();
        return false;
    }

    if(frm.drv_end.value=="") {
        alert("도착Km 입력되지 않았습니다.")
        frm.drv_end.focus();
        return false;
    }
}